# OpenHarness SOC Agent — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env — it contains secrets.

# --- FortiAnalyzer --------------------------------------------------------
FAZ_HOST=https://your-faz-host
FAZ_USER=your_api_user
FAZ_PASSWORD=your_password
FAZ_ADOMS="ADOM1:description1,ADOM2:description2"
FAZ_VERIFY_SSL=false

# --- FortiSOAR (prod) -----------------------------------------------------
FORTISOAR_URL=https://your-fortisoar-host
FORTISOAR_PUBLIC_KEY_FILE=/path/to/fsr-prod.pub
FORTISOAR_PRIVATE_KEY_FILE=/path/to/fsr-prod.priv
FORTISOAR_TENANT="Your Tenant Name"
FORTISOAR_SOURCE=Your_Alert_Source
FORTISOAR_VERIFY_SSL=false

# --- SOC whitelist ---------------------------------------------------------
# Path to the human-curated YAML whitelist of IPs/CIDRs that should be
# auto-closed without LLM investigation. Unset = no whitelist.
SOC_WHITELIST_FILE=config/soc_whitelist.yaml

# --- LLM server ------------------------------------------------------------
OH_API_FORMAT=openai
OH_BASE_URL=http://your-vllm-host:8000/v1
OH_API_KEY=sk-dummy-key
OH_MODEL=google/gemma-4-26B-A4B-it
# Temperature: 0.0–2.0. Lower = more deterministic. For SOC batch: 0.1–0.3.
OH_TEMPERATURE=0.2
